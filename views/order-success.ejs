<%- include('partials/header') %>

<style>
    .footer {
        display: none;
    }

    .history-redirect-loader {
        position: fixed;
        inset: 0;
        z-index: 99999;
        display: none;
        align-items: center;
        justify-content: center;
        background: var(--bg);
        color: var(--primary);
    }

    .history-redirect-loader.active {
        display: flex;
    }

    .history-redirect-loader-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
        font-weight: 700;
        color: var(--text-muted);
    }

    .history-redirect-spinner {
        width: 58px;
        height: 58px;
        border-radius: 50%;
        border: 4px solid rgba(0, 107, 29, 0.12);
        border-top-color: var(--primary);
        animation: historyRedirectSpin 0.8s linear infinite;
    }

    html.order-success-redirecting .order-success-section {
        visibility: hidden;
    }

    @keyframes historyRedirectSpin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="history-redirect-loader" id="historyRedirectLoader" aria-live="polite" aria-label="Redirecting">
    <div class="history-redirect-loader-inner">
        <div class="history-redirect-spinner"></div>
        <span>Opening your orders...</span>
    </div>
</div>

<script>
    (function guardOrderSuccessVisit() {
        const redirectTarget = '/profile#orders';
        const successTokenKey = 'geetakalp_order_success_order_id';
        const orderId = new URLSearchParams(window.location.search).get('orderId') || '';
        const navEntry = performance.getEntriesByType && performance.getEntriesByType('navigation')[0];

        function redirectWithLoader() {
            document.documentElement.classList.add('order-success-redirecting');
            const loader = document.getElementById('historyRedirectLoader');
            if (loader) loader.classList.add('active');
            window.setTimeout(() => window.location.replace(redirectTarget), 80);
        }

        function hasValidSuccessToken() {
            try {
                const allowedOrderId = sessionStorage.getItem(successTokenKey);
                if (orderId && allowedOrderId === orderId) {
                    sessionStorage.removeItem(successTokenKey);
                    return true;
                }
            } catch (err) {
                console.warn('Unable to validate order success navigation', err);
            }
            return false;
        }

        if (!hasValidSuccessToken()) {
            redirectWithLoader();
            return;
        }

        if (navEntry && navEntry.type === 'back_forward') {
            redirectWithLoader();
            return;
        }

        window.addEventListener('pageshow', (event) => {
            if (event.persisted) {
                redirectWithLoader();
            }
        });
    })();
</script>

<section class="section order-success-section animate-success">
    <div class="container">
        <div class="success-load-animation" id="successLoadAnimation" aria-hidden="true">
            <div class="success-load-ring">
                <i class="fas fa-check"></i>
            </div>
        </div>

        <div class="success-card" id="successCard">
            <div class="success-icon" aria-hidden="true">
                <i class="fas fa-check-circle"></i>
            </div>
            <h1>Order Confirmed!</h1>
            <p class="success-msg">Thank you for shopping with Geeta Kalp. Your order has been placed successfully.</p>
            <% if (orderId) { %>
            <div class="order-id-badge">
                <span>Order ID:</span>
                <strong><%= orderId %></strong>
            </div>
            <% } %>
            <p class="success-note">You'll receive a confirmation email shortly with your order details.</p>
            <div class="success-actions">
                <a href="/shop" class="btn btn-primary">Continue Shopping</a>
                <a href="/" class="btn btn-outline">Back to Home</a>
            </div>
        </div>
    </div>
</section>

<script>
    function revealOrderSuccess() {
        const loader = document.getElementById('successLoadAnimation');
        const card = document.getElementById('successCard');
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        window.setTimeout(() => {
            if (loader) loader.classList.add('hide');
            if (card) card.classList.add('show');
        }, prefersReducedMotion ? 0 : 950);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', revealOrderSuccess);
    } else {
        revealOrderSuccess();
    }
</script>

<%- include('partials/footer') %>
