<%- include('partials/header') %>

<!-- Hero Section -->
<section class="hero">
    <div class="hero-bg"></div>
    <!-- Decorative Orbs -->
    <div class="glass-orb" style="width: 250px; height: 250px; position: absolute; top: 10%; left: -5%; border-radius: 50%; background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.1)); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.4); z-index: 1;"></div>
    <div class="glass-orb" style="width: 400px; height: 400px; position: absolute; bottom: -10%; right: -5%; border-radius: 50%; background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0.05)); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.3); z-index: 1;"></div>
    
    <div class="container hero-content" style="position: relative; z-index: 2;">
        <div class="hero-badge animate-in">The Botanical Collection</div>
        <h1 class="hero-title animate-in">
            Cultivate Your <br><span class="gradient-text">Inner Stillness</span>
        </h1>
        <p class="hero-subtitle animate-in">Harness the profound silence of nature with our ethically sourced botanical rituals, designed to ground your spirit and illuminate your essence.</p>
        <div class="hero-actions animate-in">
            <a href="/shop" class="btn btn-primary btn-lg">
                <span>Explore Botanicals</span>
            </a>
            <a href="/shop?sort=discount" class="btn btn-outline btn-lg">
                <span>View Sets</span>
            </a>
        </div>
        <div class="hero-stats animate-in">
            <div class="hero-stat">
                <span class="stat-number" data-count="100">0</span>+
                <span class="stat-label">Organic Blends</span>
            </div>
            <div class="hero-stat">
                <span class="stat-number" data-count="5000">0</span>+
                <span class="stat-label">Rituals Crafted</span>
            </div>
            <div class="hero-stat">
                <span class="stat-number" data-count="100">0</span>%
                <span class="stat-label">Ethically Sourced</span>
            </div>
        </div>
    </div>
</section>

<!-- Features Strip -->
<section class="features-strip">
    <div class="container features-grid">
        <div class="feature-item">
            <div class="feature-icon"><i class="fas fa-truck-fast"></i></div>
            <div>
                <strong>Free Delivery</strong>
                <span>Orders above ₹999</span>
            </div>
        </div>
        <div class="feature-item">
            <div class="feature-icon"><i class="fas fa-shield-halved"></i></div>
            <div>
                <strong>Secure Payment</strong>
                <span>100% Protected</span>
            </div>
        </div>
        <div class="feature-item">
            <div class="feature-icon"><i class="fas fa-rotate-left"></i></div>
            <div>
                <strong>Easy Returns</strong>
                <span>7-Day Returns</span>
            </div>
        </div>
        <div class="feature-item">
            <div class="feature-icon"><i class="fas fa-headset"></i></div>
            <div>
                <strong>24/7 Support</strong>
                <span>Dedicated Help</span>
            </div>
        </div>
    </div>
</section>

<!-- New Arrivals Section -->
<% if (newProducts && newProducts.length > 0) { %>
<section class="section" id="new-arrivals">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">✨ Just In</span>
            <h2 class="section-title">New Arrivals</h2>
            <p class="section-subtitle">Freshly added to our collection</p>
        </div>
        <div class="products-grid">
            <% newProducts.slice(0, 4).forEach(product => { %>
            <div class="product-card" data-aos="fade-up">
                <a href="/product/<%= product.id %>" class="product-card-link">
                    <div class="product-image-wrap">
                        <div class="product-image-mask">
                        <% if (product.images && product.images.length > 0) { %>
                        <img src="<%= product.images[0] %>" alt="<%= product.name %>" class="product-image" loading="lazy">
                        <% } else { %>
                        <div class="product-image product-placeholder">
                            <i class="fas fa-image"></i>
                        </div>
                        <% } %>
                        </div>
                        <div class="product-badges">
                            <% const badgeType = product.productBadgeType || (product.isNew ? 'new' : 'none'); %>
                            <% if (badgeType === 'new') { %>
                            <span class="badge badge-new">NEW</span>
                            <% } else if (badgeType === 'trending') { %>
                            <span class="badge badge-trending">Trending</span>
                            <% } else if (badgeType === 'custom' && product.productBadgeText) { %>
                            <span class="badge badge-custom"><%= product.productBadgeText %></span>
                            <% } %>
                            <% if (product.originalPrice > product.salePrice) { %>
                            <span class="badge badge-discount">-<%= Math.round(((product.originalPrice - product.salePrice) / product.originalPrice) * 100) %>%</span>
                            <% } %>
                        </div>
                        <div class="product-overlay">
                            <button class="quick-add-btn" onclick="event.preventDefault(); addToCart('<%= product.id %>', '<%= product.name %>', <%= product.salePrice %>, <%= product.originalPrice %>, '<%= product.images && product.images[0] ? product.images[0] : '' %>')">
                                <i class="fas fa-shopping-bag"></i> Add to Cart
                            </button>
                            <button class="quick-view-trigger" onclick="event.preventDefault(); openQuickView('<%= product.id %>')" aria-label="Quick View">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <button class="wishlist-btn" data-wishlist-id="<%= product.id %>" onclick="event.preventDefault(); WishlistManager.toggle('<%= product.id %>')" aria-label="Add to wishlist">
                            <i class="far fa-heart"></i>
                        </button>
                    </div>
                    <div class="product-info">
                        <span class="product-category"><%= product.category %></span>
                        <h3 class="product-name"><%= product.name %></h3>
                        <div class="product-pricing">
                            <span class="current-price">₹<%= product.salePrice.toLocaleString('en-IN') %></span>
                            <% if (product.originalPrice > product.salePrice) { %>
                            <span class="original-price">₹<%= product.originalPrice.toLocaleString('en-IN') %></span>
                            <span class="discount-tag">Save ₹<%= (product.originalPrice - product.salePrice).toLocaleString('en-IN') %></span>
                            <% } %>
                        </div>
                    </div>
                </a>
            </div>
            <% }); %>
        </div>
    </div>
</section>
<% } %>

