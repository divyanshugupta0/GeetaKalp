<%- include('partials/header') %>

<section class="section product-detail-section">
    <div class="container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <i class="fas fa-chevron-right"></i>
            <a href="/shop">Shop</a>
            <i class="fas fa-chevron-right"></i>
            <a href="/shop?category=<%= product.category %>"><%= product.category %></a>
            <i class="fas fa-chevron-right"></i>
            <span><%= product.name %></span>
        </nav>

        <div class="product-detail-grid">
            <!-- Product Images -->
            <div class="product-gallery">
                <div class="main-image-wrap zoom-container" id="zoomContainer">
                    <% if (product.images && product.images.length > 0) { %>
                    <img src="<%= product.images[0] %>" alt="<%= product.name %>" class="main-image" id="mainImage">
                    <% } else { %>
                    <div class="main-image product-placeholder">
                        <i class="fas fa-image"></i>
                    </div>
                    <% } %>
                    <div class="product-badges">
                        <% const mainBadgeType = product.productBadgeType || (product.isNew ? 'new' : 'none'); %>
                        <% if (mainBadgeType === 'new') { %>
                        <span class="badge badge-new badge-lg">NEW</span>
                        <% } else if (mainBadgeType === 'trending') { %>
                        <span class="badge badge-trending badge-lg">Trending</span>
                        <% } else if (mainBadgeType === 'custom' && product.productBadgeText) { %>
                        <span class="badge badge-custom badge-lg"><%= product.productBadgeText %></span>
                        <% } %>
                        <% if (product.discountPercent > 0) { %>
                        <span class="badge badge-discount badge-lg">-<%= product.discountPercent %>%</span>
                        <% } %>
                    </div>
                    <button type="button" class="product-share-btn" onclick="shareProduct()" aria-label="Share product">
                        <i class="fas fa-share-nodes"></i>
                    </button>
                </div>
                <% if (product.images && product.images.length > 1) { %>
                <div class="thumbnail-row">
                    <% product.images.forEach((img, i) => { %>
                    <button class="thumb-btn <%= i === 0 ? 'active' : '' %>" onclick="changeImage('<%= img %>', this)">
                        <img src="<%= img %>" alt="<%= product.name %> view <%= i + 1 %>">
                    </button>
                    <% }); %>
                </div>
                <% } %>
            </div>

            <!-- Product Info -->
            <div class="product-detail-info">
                <span class="product-category-tag"><%= product.category %></span>
                <h1 class="product-detail-name"><%= product.name %></h1>

                <!-- Pricing -->
                <div class="product-detail-pricing">
                    <div class="price-row">
                        <span class="detail-current-price">₹<%= product.salePrice.toLocaleString('en-IN') %></span>
                        <% if (product.originalPrice > product.salePrice) { %>
                        <span class="detail-original-price">₹<%= product.originalPrice.toLocaleString('en-IN') %></span>
                        <% } %>
                    </div>
                    <% if (product.discountPercent > 0) { %>
                    <div class="savings-banner">
                        <i class="fas fa-tag"></i>
                        You save ₹<%= (product.originalPrice - product.salePrice).toLocaleString('en-IN') %> (<%= product.discountPercent %>% OFF)
                    </div>
                    <% } %>
                </div>

                <!-- Description -->
                <% if (product.description) { %>
                <div class="product-description">
                    <h3>Description</h3>
                    <p><%= product.description %></p>
                </div>
                <% } %>

                <!-- Stock Status -->
                <div class="stock-status">
                    <% if (product.stock > 0) { %>
                    <span class="in-stock"><i class="fas fa-check-circle"></i> In Stock (<%= product.stock %> available)</span>
                    <% } else { %>
                    <span class="out-of-stock"><i class="fas fa-times-circle"></i> Out of Stock</span>
                    <% } %>
                </div>

                <!-- Quantity & Add to Cart -->
                <div class="product-actions">
                    <div class="quantity-selector">
                        <button class="qty-btn" onclick="changeQty(-1)">−</button>
                        <input type="number" class="qty-input" id="quantity" value="1" min="1" max="<%= product.stock || 99 %>">
                        <button class="qty-btn" onclick="changeQty(1)">+</button>
                    </div>
                    <button class="btn btn-primary btn-lg add-to-cart-btn" id="addToCartBtn"
                        onclick="addToCart('<%= product.id %>', '<%= product.name %>', <%= product.salePrice %>, <%= product.originalPrice %>, '<%= product.images && product.images[0] ? product.images[0] : '' %>', parseInt(document.getElementById('quantity').value))"
                        <%= product.stock === 0 ? 'disabled' : '' %>>
                        <i class="fas fa-shopping-bag"></i>
                        <span>Add to Cart</span>
                    </button>
                    <button class="product-wishlist-detail" data-wishlist-id="<%= product.id %>" onclick="WishlistManager.toggle('<%= product.id %>')">
                        <i class="far fa-heart"></i> <span>Wishlist</span>
                    </button>
                </div>

                <!-- Trust Badges -->
                <div class="trust-badges">
                    <div class="trust-badge">
                        <i class="fas fa-truck"></i>
                        <span>Free Delivery</span>
                    </div>
                    <div class="trust-badge">
                        <i class="fas fa-shield-halved"></i>
                        <span>Secure Payment</span>
                    </div>
                    <div class="trust-badge">
                        <i class="fas fa-rotate-left"></i>
                        <span>Easy Returns</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Customer Reviews -->
        <div class="reviews-section" style="margin-top: 60px; padding-top: 40px; border-top: 1px solid var(--border); margin-bottom: 60px;">
            <h2 class="section-title">Customer Reviews</h2>
            <% if (typeof reviews !== 'undefined' && reviews.length > 0) { %>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px;">
                    <% reviews.forEach(r => { %>
                        <div style="background: var(--bg-card); padding: 24px; border-radius: var(--radius-lg); border: 1px solid var(--border);">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px;">
                                <div>
                                    <h4 style="margin: 0; font-size: 1.1rem;"><%= r.customerName %></h4>
                                    <div style="font-size: 0.8rem; color: var(--text-muted);"><%= new Date(r.createdAt).toLocaleDateString('en-IN') %></div>
                                </div>
                                <div style="color: #fbbf24; font-size: 0.9rem;">
                                    <% for(let i=1; i<=5; i++) { %>
                                        <i class="fas fa-star" style="<%= i <= r.rating ? '' : 'color: #e5e7eb;' %>"></i>
                                    <% } %>
                                </div>
                            </div>
                            <p style="margin: 0; color: var(--text-dim); font-size: 0.95rem; line-height: 1.6;"><%= r.comment %></p>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div style="text-align: center; padding: 40px; background: var(--bg-elevated); border-radius: var(--radius-lg);">
                    <i class="fas fa-comment-slash" style="font-size: 2.5rem; color: var(--text-dim); margin-bottom: 16px;"></i>
                    <p style="color: var(--text-muted); margin: 0;">No reviews yet. Purchase this product to leave a review!</p>
                </div>
            <% } %>
        </div>

        <!-- Related Products -->
        <% if (relatedProducts && relatedProducts.length > 0) { %>
        <div class="related-section">
            <h2 class="section-title">Related Products</h2>
            <div class="products-grid">
                <% relatedProducts.forEach(rp => { %>
                <div class="product-card">
                    <a href="/product/<%= rp.id %>" class="product-card-link">
                        <div class="product-image-wrap">
                            <div class="product-image-mask">
                            <% if (rp.images && rp.images.length > 0) { %>
                            <img src="<%= rp.images[0] %>" alt="<%= rp.name %>" class="product-image" loading="lazy">
                            <% } else { %>
                            <div class="product-image product-placeholder"><i class="fas fa-image"></i></div>
                            <% } %>
                            </div>
                            <div class="product-badges">
                                <% const relatedBadgeType = rp.productBadgeType || (rp.isNew ? 'new' : 'none'); %>
                                <% if (relatedBadgeType === 'new') { %><span class="badge badge-new">NEW</span><% } %>
                                <% if (relatedBadgeType === 'trending') { %><span class="badge badge-trending">Trending</span><% } %>
                                <% if (relatedBadgeType === 'custom' && rp.productBadgeText) { %><span class="badge badge-custom"><%= rp.productBadgeText %></span><% } %>
                                <% if (rp.originalPrice > rp.salePrice) { %>
                                <span class="badge badge-discount">-<%= Math.round(((rp.originalPrice - rp.salePrice) / rp.originalPrice) * 100) %>%</span>
                                <% } %>
                            </div>
                        </div>
                        <div class="product-info">
                            <h3 class="product-name"><%= rp.name %></h3>
                            <div class="product-pricing">
                                <span class="current-price">₹<%= rp.salePrice.toLocaleString('en-IN') %></span>
                                <% if (rp.originalPrice > rp.salePrice) { %>
                                <span class="original-price">₹<%= rp.originalPrice.toLocaleString('en-IN') %></span>
                                <% } %>
                            </div>
                        </div>
                    </a>
                </div>
                <% }); %>
            </div>
        </div>
        <% } %>

        <!-- Recently Viewed Products -->
        <div class="recently-viewed-section" id="recentlyViewedSection" style="display: none;">
            <div class="rv-header">
                <h2 class="section-title" style="font-size: 1.6rem;">Recently Viewed</h2>
                <button class="rv-clear" onclick="clearRecentlyViewed()"><i class="fas fa-trash-alt"></i> Clear</button>
            </div>
            <div class="recently-viewed-scroll" id="recentlyViewedScroll"></div>
        </div>
    </div>
</section>

<!-- Structured Data for SEO -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "<%= product.name %>",
    "description": "<%= product.description ? product.description.replace(/"/g, '\\"') : '' %>",
    "category": "<%= product.category %>",
    <% if (product.images && product.images.length > 0) { %>
    "image": "<%= product.images[0] %>",
    <% } %>
    "offers": {
        "@type": "Offer",
        "price": "<%= product.salePrice %>",
        "priceCurrency": "INR",
        "availability": "<%= product.stock > 0 ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock' %>"
    }
}
</script>

<script>
    function changeImage(src, btn) {
        document.getElementById('mainImage').src = src;
        document.querySelectorAll('.thumb-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
    }

    function changeQty(delta) {
        const input = document.getElementById('quantity');
        let val = parseInt(input.value) + delta;
        if (val < 1) val = 1;
        if (val > parseInt(input.max)) val = parseInt(input.max);
        input.value = val;
    }

    async function shareProduct() {
        const shareData = {
            title: <%- JSON.stringify(product.name) %>,
            text: <%- JSON.stringify(`Check out ${product.name} on Geeta Kalp`) %>,
            url: window.location.href
        };

        try {
            if (navigator.share) {
                await navigator.share(shareData);
                return;
            }

            await navigator.clipboard.writeText(window.location.href);
            if (typeof showToast === 'function') {
                showToast('Product link copied');
            }
        } catch (error) {
            if (error && error.name === 'AbortError') return;
            if (typeof showToast === 'function') {
                showToast('Could not share product', 'error');
            }
        }
    }
</script>

<script>
    // ── Image Zoom ──
    const zoomContainer = document.getElementById('zoomContainer');
    const mainImageEl = document.getElementById('mainImage');
    if (zoomContainer && mainImageEl) {
        let isZoomed = false;
        zoomContainer.addEventListener('mousemove', (e) => {
            if (window.innerWidth < 768) return;
            const rect = zoomContainer.getBoundingClientRect();
            const x = ((e.clientX - rect.left) / rect.width) * 100;
            const y = ((e.clientY - rect.top) / rect.height) * 100;
            mainImageEl.style.transformOrigin = `${x}% ${y}%`;
            if (isZoomed) mainImageEl.style.transform = 'scale(2)';
        });
        zoomContainer.addEventListener('click', () => {
            if (window.innerWidth < 768) return;
            isZoomed = !isZoomed;
            zoomContainer.classList.toggle('zoomed', isZoomed);
            mainImageEl.style.transform = isZoomed ? 'scale(2)' : 'scale(1)';
        });
        zoomContainer.addEventListener('mouseleave', () => {
            isZoomed = false;
            zoomContainer.classList.remove('zoomed');
            mainImageEl.style.transform = 'scale(1)';
        });
    }

    // ── Recently Viewed ──
    const currentProduct = {
        id: <%- JSON.stringify(product.id) %>,
        name: <%- JSON.stringify(product.name) %>,
        salePrice: <%= product.salePrice %>,
        image: <%- JSON.stringify(product.images && product.images[0] ? product.images[0] : '') %>
    };
    function getRecentlyViewed() {
        try { return JSON.parse(localStorage.getItem('recentlyViewed') || '[]'); } catch { return []; }
    }
    function saveRecentlyViewed(items) {
        localStorage.setItem('recentlyViewed', JSON.stringify(items));
    }
    let rv = getRecentlyViewed().filter(p => p.id !== currentProduct.id);
    rv.unshift(currentProduct);
    if (rv.length > 10) rv = rv.slice(0, 10);
    saveRecentlyViewed(rv);

    function renderRecentlyViewed() {
        const items = getRecentlyViewed().filter(p => p.id !== currentProduct.id);
        const section = document.getElementById('recentlyViewedSection');
        const scroll = document.getElementById('recentlyViewedScroll');
        if (!items.length || !section || !scroll) return;
        section.style.display = 'block';
        scroll.innerHTML = items.map(p => `
            <a href="/product/${p.id}" class="recently-viewed-item">
                ${p.image ? `<img src="${p.image}" alt="${p.name}" class="recently-viewed-img">` : '<div class="recently-viewed-img" style="display:flex;align-items:center;justify-content:center;"><i class="fas fa-image" style="color:var(--text-dim);"></i></div>'}
                <div class="recently-viewed-name">${p.name}</div>
                <div class="recently-viewed-price">₹${Number(p.salePrice).toLocaleString('en-IN')}</div>
            </a>
        `).join('');
    }
    function clearRecentlyViewed() {
        localStorage.removeItem('recentlyViewed');
        document.getElementById('recentlyViewedSection').style.display = 'none';
        if (typeof showToast === 'function') showToast('History cleared');
    }
    renderRecentlyViewed();
</script>

<%- include('partials/footer') %>
